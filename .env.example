# Local runtime mode. Keep mock for stable competition demos without API keys.
API_MODE=mock

# Provider presets:
# - china-qwen: Qwen/Bailian ASR + LLM + TTS + text assessment for first domestic run.
# - global-mixed: AssemblyAI ASR + OpenAI-compatible LLM + Cartesia TTS.
# - custom: manually configure providers below.
API_PROVIDER_PRESET=china-qwen

# Generic provider switches for the first domestic API run.
ASR_PROVIDER=qwen-asr
ASR_MODEL=qwen3-asr-flash
LLM_PROVIDER=qwen
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
TTS_PROVIDER=qwen-tts
TTS_MODEL=qwen3-tts-flash
TTS_VOICE_ID=Cherry
PRONUNCIATION_PROVIDER=qwen

# Generic keys. Fill locally only; never commit real values.
ASR_API_KEY=
LLM_API_KEY=
TTS_API_KEY=
TTS_VOICE_ID=
TTS_VERSION=

# Domestic LLM aliases supported by the backend.
DASHSCOPE_API_KEY=
ARK_API_KEY=
MOONSHOT_API_KEY=

# AssemblyAI ASR, required when ASR_PROVIDER=assemblyai.
ASSEMBLYAI_API_KEY=

# Deepgram ASR, only required when API_MODE=live.
DEEPGRAM_API_KEY=

# OpenAI LLM, only required when API_MODE=live.
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini

# Cartesia TTS, only required when API_MODE=live.
CARTESIA_API_KEY=
CARTESIA_VERSION=2026-03-01
CARTESIA_TTS_MODEL=sonic-3.5
CARTESIA_VOICE_ID=

# Local API port.
PORT=5174
