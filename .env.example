# Local runtime mode. Keep mock for stable competition demos without API keys.
API_MODE=mock

# Provider presets:
# - global-mixed: AssemblyAI ASR + OpenAI-compatible LLM + Cartesia TTS.
# - china-qwen: Qwen/Bailian ASR + LLM + TTS + text assessment for optional domestic run.
# - custom: manually configure providers below.
API_PROVIDER_PRESET=global-mixed

# Generic provider switches for the current competition mixed run.
ASR_PROVIDER=assemblyai
ASR_MODEL=universal-3-pro
LLM_PROVIDER=custom-openai-compatible
LLM_BASE_URL=https://hezu.ink/v1
LLM_MODEL=gpt-5.4-mini
TTS_PROVIDER=cartesia
TTS_MODEL=sonic-3.5
TTS_VOICE_ID=
PRONUNCIATION_PROVIDER=rule

# Generic keys. Fill locally only; never commit real values.
ASR_API_KEY=
LLM_API_KEY=
TTS_API_KEY=
TTS_VOICE_ID=
TTS_VERSION=

# Domestic LLM aliases supported by the backend.
DASHSCOPE_API_KEY=
ARK_API_KEY=
MOONSHOT_API_KEY=

# AssemblyAI ASR, required when ASR_PROVIDER=assemblyai.
ASSEMBLYAI_API_KEY=

# Deepgram ASR, only required when API_MODE=live.
DEEPGRAM_API_KEY=

# OpenAI LLM, only required when API_MODE=live.
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini

# Cartesia TTS, only required when API_MODE=live.
CARTESIA_API_KEY=
CARTESIA_VERSION=2026-03-01
CARTESIA_TTS_MODEL=sonic-3.5
CARTESIA_VOICE_ID=

# Local API port.
PORT=5174

# Browser -> Pipecat Voice Agent bridge.
VITE_PIPECAT_BASE_URL=http://127.0.0.1:7860
VITE_BUSINESS_API_URL=http://127.0.0.1:5174
