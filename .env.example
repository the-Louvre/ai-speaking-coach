# Local runtime mode. Keep mock for stable competition demos without API keys.
API_MODE=mock

# Provider presets:
# - china-qwen: Qwen/Bailian LLM live path with mock ASR/TTS fallback for first domestic run.
# - global-mixed: Deepgram ASR + OpenAI LLM + Cartesia TTS.
# - custom: manually configure providers below.
API_PROVIDER_PRESET=china-qwen

# Generic provider switches. Keep mock speech for the first domestic API run.
ASR_PROVIDER=mock
LLM_PROVIDER=qwen
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
TTS_PROVIDER=mock
TTS_MODEL=mock
PRONUNCIATION_PROVIDER=rule

# Generic keys. Fill locally only; never commit real values.
ASR_API_KEY=
LLM_API_KEY=
TTS_API_KEY=
TTS_VOICE_ID=
TTS_VERSION=

# Domestic LLM aliases supported by the backend.
DASHSCOPE_API_KEY=
ARK_API_KEY=
MOONSHOT_API_KEY=

# Deepgram ASR, only required when API_MODE=live.
DEEPGRAM_API_KEY=

# AssemblyAI ASR, only required when ASR_PROVIDER=assemblyai.
ASSEMBLYAI_API_KEY=

# OpenAI LLM, only required when API_MODE=live.
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini

# Cartesia TTS, only required when API_MODE=live.
CARTESIA_API_KEY=
CARTESIA_VERSION=2026-03-01
CARTESIA_TTS_MODEL=sonic-latest
CARTESIA_VOICE_ID=

# Optional prompt file or inline prompt appended to LLM system prompts.
DEFAULT_PROMPT_PATH=
DEFAULT_PROMPT=

# Local API port.
PORT=5174
